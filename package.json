{
  "name": "cv-generator",
  "version": "0.1.0",
  "description": "Vite+React PDF CV generator — reads cv-entries-current.json, renders print-ready CV, exports PDF via Playwright",
  "private": true,
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "prepare-cv-data": "node scripts/prepare-cv-data.mjs",
    "export-pdf": "node scripts/export-pdf.mjs",
    "generate": "node scripts/prepare-cv-data.mjs && node scripts/export-pdf.mjs"
  },
  "dependencies": {
    "react": "^18.3.0",
    "react-dom": "^18.3.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.1",
    "playwright": "^1.45.0",
    "vite": "^5.4.0"
  }
}
